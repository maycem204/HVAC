# Node.js/Express + PostgreSQL/pgvector + DeepSeek
APP_ENV=local
NODE_ENV=development
APP_URL=http://127.0.0.1:8080

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=hvac_quotes
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Secrets backend uniquement. Copiez ce fichier vers .env à la racine.
DEEPSEEK_API_KEY=change-me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Fournisseur actif : deepseek, openai ou anthropic (claude est aussi accepté).
# AI_PROVIDER est le nom principal. Les anciennes variables LLM_* restent compatibles.
AI_PROVIDER=deepseek
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=
# Développement local : serveur compatible OpenAI (TEI, vLLM ou llama.cpp).
# En production, utilisez une API distante; ne laissez jamais 127.0.0.1 sauf
# si un serveur d'embeddings tourne dans le même conteneur.
# Exemple OpenAI : URL https://api.openai.com/v1, modèle
# text-embedding-3-small et EMBEDDING_REQUEST_DIMENSIONS=true.
EMBEDDING_API_KEY=
EMBEDDING_ENABLED=true
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_BASE_URL=http://127.0.0.1:8081/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_DIMENSIONS=1024
# Activez ce paramètre avec les modèles OpenAI text-embedding-3 afin que
# l'API renvoie directement la dimension attendue par pgvector.
EMBEDDING_REQUEST_DIMENSIONS=false
EMBEDDING_QUERY_INSTRUCTION=Retrieve the HVAC fault catalog entry that best matches the user request
EMBEDDING_BATCH_SIZE=8
EMBEDDING_TIMEOUT_MS=180000
# En cas de quota gratuit 429, l'indexation reprend automatiquement après 15 min.
EMBEDDING_QUOTA_RETRY_MS=900000
PRICING_LLM_TIMEOUT_MS=30000
GEOCODING_PROVIDER=nominatim
GEOCODING_BASE_URL=https://nominatim.openstreetmap.org
GEOCODING_USER_AGENT=QuoteAI-HVAC/1.0
GEOCODING_API_KEY=
# Origines autorisées par la politique CSP du backend, séparées par des virgules.
MAP_TILE_ORIGINS=https://tile.openstreetmap.org

DATABASE_URL=postgresql://quoteai:change-me@127.0.0.1:5433/quoteai_db
JWT_SECRET=change-me-at-least-32-characters
JWT_EXPIRES_IN=7d
JWT_ISSUER=quoteai-api
JWT_AUDIENCE=quoteai-web
# Durée de vie du cookie HttpOnly, alignée par défaut sur JWT_EXPIRES_IN=7d.
AUTH_COOKIE_MAX_AGE_MS=604800000
BCRYPT_ROUNDS=10
PORT=5000
CORS_ORIGINS=http://localhost:5174,http://localhost:3000,http://127.0.0.1:5174,http://127.0.0.1:3000
# En production : https://votre-domaine.com (sans barre oblique finale)

# Seed script demo accounts (local dev only)
SEED_CLIENT_PASSWORD=Client@123
SEED_TECH_PASSWORD=Tech@123

# React/Vite frontend
VITE_API_URL=http://127.0.0.1:5000
# Remplacez par un fournisseur OSM avec SLA avant une mise en production à fort trafic.
VITE_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_MAP_TILE_ATTRIBUTION=&copy; OpenStreetMap contributors
VITE_DIRECTIONS_PROVIDER=google
VITE_DIRECTIONS_BASE_URL=https://www.google.com/maps/dir/
